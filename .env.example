FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_NAME=股票助手
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude CLI — default is "claude", on Windows use full path like:
# CLAUDE_CMD=C:\Users\YourName\AppData\Roaming\npm\claude.cmd
CLAUDE_CMD=claude
CLAUDE_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
# Crash alert — comma-separated chat IDs to notify on bot crash
ALERT_CHAT_IDS=oc_xxxxxxxxxxxxxxxx
